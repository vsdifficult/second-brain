{
  "ReverseProxy": {
    "Routes": {
      "brain-api": {
        "ClusterId": "brain-cluster",
        "Match": {
          "Path": "/brain/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      },
      "user-api": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/user/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "brain-cluster": {
        "Destinations": {
          "brain": {
            "Address": "https://localhost:7001/"
          }
        }
      },
      "user-cluster": {
        "Destinations": {
          "user": {
            "Address": "https://localhost:7002/"
          }
        }
      }
    }
  }
}
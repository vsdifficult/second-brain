{
  "ReverseProxy": {
    "Routes": {
      "brain-api": {
        "ClusterId": "brain-cluster",
        "Match": {
          "Path": "/brain/{*catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/brain" }
        ]
      },
      "user-api": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/user/{*catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/user" }
        ]
      },
      "search-api": {
        "ClusterId": "search-cluster",
        "Match": { "Path": "/search/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/search" }
        ]
      }
    },
    "Clusters": {
      "brain-cluster": {
        "Destinations": {
          "brain": {
            "Address": "http://brain-service:8080/"
          }
        }
      },
      "user-cluster": {
        "Destinations": {
          "user": {
            "Address": "http://user-service:8080/"
          }
        }
      }, 
      "search-cluster": { 
        "Destinations": {
          "search": {
            "Address": "http://search-service:8080"
          }
        }
      }
    }
  }
}
